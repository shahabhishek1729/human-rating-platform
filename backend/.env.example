# Runtime overrides
# APP__CORS_ORIGINS=["http://localhost:5173","http://localhost:8000"]
# DATABASE__URL=postgresql://postgres:postgres@localhost:5432/human_rating_platform

# Export streaming and test data
# EXPORTS__STREAM_BATCH_SIZE=1000
# TESTING__EXPORT_SEED_ROW_COUNT=1500

# Local dev seed dataset (used by make db.seed)
# SEEDING__ENABLED=false
# SEEDING__EXPERIMENT_NAME=Seed - Local Baseline
# SEEDING__QUESTION_COUNT=50
# SEEDING__NUM_RATINGS_PER_QUESTION=3
# SEEDING__PROLIFIC_COMPLETION_URL=https://app.prolific.com/submissions/complete?cc=XXXX

# Admin allowlist + session cookie (Clerk frontend; HTTP-only cookie backend)
# Comma-separated list of emails or JSON array. Example:
# ADMIN_ALLOWLIST=alice@example.com,bob@example.com
# ADMIN_ALLOWLIST=["alice@example.com","bob@example.com"]
# Secret for HMAC signing of the admin session cookie.
# Safe default for local dev / CI; override with a strong random value in real deployments.
APP_SECRET_KEY=please-change-me-to-a-long-random-string
# Dedicated rater-session token secret (falls back to APP_SECRET_KEY if unset)
# Set a distinct value to reduce blast radius and enable independent rotation.
# RATER_SESSION_SECRET_KEY=please-change-me-to-a-long-random-string-for-raters
# Rater-session token TTL in seconds.
# Defaults to the session duration (3600 seconds = 60 minutes).
# RATER_SESSION_TTL_SECONDS=3600
# Cookie name/max-age and security flag
# HRP_SESSION_COOKIE=hrp_session
# HRP_SESSION_MAX_AGE=604800
# COOKIE_SECURE=false
# Note: COOKIE_SECURE=false → SameSite=Lax (local dev); true → SameSite=None; Secure (production)

# Clerk JWT verification (for /admin/auth/login)
# Set to your Clerk instance values. Example for dev:
# CLERK__ISSUER=https://mutual-malamute-81.clerk.accounts.dev
# CLERK__JWKS_URL=https://mutual-malamute-81.clerk.accounts.dev/.well-known/jwks.json
# Audience your JWT template sets (required when verifying aud):
# CLERK__AUDIENCE=human-rating-platform-admin-api

# Prolific integration mode:
# Prolific API integration (set to enable automated study management)
# PROLIFIC__API_TOKEN=your-prolific-api-token
# APP__SITE_URL=http://localhost:5173
# Project to create studies under. Find the ID in the URL when viewing a
# project (`/researcher/workspaces/projects/<id>`). If unset, Prolific uses
# the API user's `current_project_id`, which can land studies in the wrong
# workspace on multi-workspace accounts.
# PROLIFIC__PROJECT_ID=
# Workspace that owns PROLIFIC__PROJECT_ID. Find the ID in the URL when
# viewing the workspace home (`/researcher/workspaces/<id>/home`). Used to
# look up the workspace's currency for the pilot/round form's reward hint,
# and to validate that PROJECT_ID actually lives in this workspace at
# startup. The form falls back to a generic "minor units" hint if unset or
# if the lookup fails.
# PROLIFIC__WORKSPACE_ID=

# LLM integration (required for assistance methods that use AI)
# LLM__DEFAULT_MODEL=openrouter/anthropic/claude-sonnet-4-6
# LLM__OPENROUTER_API_KEY=sk-or-...
# LLM__MAX_TOKENS=4096
